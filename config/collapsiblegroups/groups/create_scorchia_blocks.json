{
  "id": "create_scorchia_blocks",
  "name": {
    "translate": "collapsible_groups.group.create_scorchia_blocks",
    "fallback": "Create: Scorchia Blocks"
  },
  "enabled": true,
  "filter": {
    "all": [
      {
        "any": [
          {
            "type": "item",
            "namespace": "create"
          },
          {
            "type": "item",
            "namespace": "create_chipped"
          }
        ]
      },
      {
        "any": [
          {
            "item_path_starts_with": "scorchia"
          },
          {
            "item_path_starts_with": "cut_scorchia"
          },
          {
            "item_path_starts_with": "polished_cut_scorchia"
          },
          {
            "item_path_starts_with": "small_scorchia"
          },
          {
            "item_path_starts_with": "layered_scorchia"
          }
        ]
      }
    ]
  }
}