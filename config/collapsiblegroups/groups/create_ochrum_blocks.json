{
  "id": "create_ochrum_blocks",
  "name": {
    "translate": "collapsible_groups.group.create_ochrum_blocks",
    "fallback": "Create: Ochrum Blocks"
  },
  "enabled": true,
  "filter": {
    "all": [
      {
        "any": [
          {
            "type": "item",
            "namespace": "create"
          },
          {
            "type": "item",
            "namespace": "create_chipped"
          }
        ]
      },
      {
        "any": [
          {
            "item_path_starts_with": "ochrum"
          },
          {
            "item_path_starts_with": "cut_ochrum"
          },
          {
            "item_path_starts_with": "polished_cut_ochrum"
          },
          {
            "item_path_starts_with": "small_ochrum"
          },
          {
            "item_path_starts_with": "layered_ochrum"
          }
        ]
      }
    ]
  }
}