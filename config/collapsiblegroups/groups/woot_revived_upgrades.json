{
  "id": "woot_revived_upgrades",
  "name": {
    "translate": "collapsible_groups.group.woot_revived_upgrades",
    "fallback": "Woot Revived: Upgrades"
  },
  "enabled": true,
  "filter": {
    "all": [
      {
        "type": "item",
        "namespace": "woot_revived"
      },
      {
        "item_path_ends_with": "_upgrade"
      },
      {
        "not": {
          "type": "item",
          "id": "woot_revived:factory_upgrade"
        }
      }
    ]
  }
}